# Copy to .env and fill in. Never commit the populated .env.

# Docker image tag built and pushed by `the deploy task runner` / `the deploy task runner`.
APP_IMAGE=etv-station:latest

# Unraid host for `the deploy task runner`. Hostname or IP reachable over SSH.
UNRAID_HOST=<your-unraid-hostname-or-ip>

# SSH user on the Unraid host. Defaults to root if unset.
UNRAID_USER=root

# Public URL the deployed station service is reachable at. Used by `the deploy task runner`
# and the URL-status display on the status home screen.
PROD_URL=https://<your-public-url>

# IANA time zone the station operates in (`station.toml`'s `tz` field is the
# file-level form; this env var overrides it at runtime). Defaults to UTC.
ETV_STATION_TZ=UTC

# Interface ETV-next binds its HTTP server to during `./tools/dev-run.sh`. Defaults
# to 0.0.0.0 so the dev stream is reachable as localhost, 127.0.0.1, the
# LAN IP, and Tailscale. Override to 127.0.0.1 for loopback only.
ETV_BIND_ADDRESS=0.0.0.0

# Port ETV-next listens on during `./tools/dev-run.sh`. Defaults to 8409.
ETV_PORT=8409

# Root of the local media library used by example channels that source local
# files (e.g. examples/channels/diehard.toml). Required for any channel whose
# `[rule.items.source]` path references ${ETV_TEST_MEDIA_DIR}. No default —
# personal/host-specific value, must be set in your `.env`.
ETV_TEST_MEDIA_DIR=<your-media-library-root>
