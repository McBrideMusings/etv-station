# Copy to .env and fill in. Never commit the populated .env.

# IANA time zone the station operates in (`station.toml`'s `tz` field is the
# file-level form; this env var overrides it at runtime). Defaults to UTC.
ETV_STATION_TZ=UTC

# Interface ETV-next binds its HTTP server to during a dev run. Defaults
# to 0.0.0.0 so the dev stream is reachable as localhost, 127.0.0.1, the
# LAN IP, and Tailscale. Override to 127.0.0.1 for loopback only.
ETV_BIND_ADDRESS=0.0.0.0

# Port ETV-next listens on during a dev run. Defaults to 8409.
ETV_PORT=8409

# Root of the local media library used by example channels that source local
# files (e.g. examples/channels/diehard.toml). Required for any channel whose
# `[rule.items.source]` path references ${ETV_TEST_MEDIA_DIR}. No default —
# personal/host-specific value, must be set in your `.env`.
ETV_TEST_MEDIA_DIR=<your-media-library-root>

# ─── Phase A: CEL feasibility study (crates/etv-query-test) ──────────────────
# Used by the etv-query-test harness (`./tools/query.sh` and batch mode).

# Plex server reachable URL (e.g. http://100.x.x.x:32400).
PLEX_URL=<your-plex-url>

# Plex API token.
PLEX_TOKEN=<your-plex-token>

# Optional path translation: rewrite Plex-side paths to locally-mounted paths.
# Leave blank if Plex and the FS scanner see identical mount points.
MEDIA_PATH_FROM=
MEDIA_PATH_TO=

# Colon-separated filesystem roots the station daemon scans into the catalog and
# uses to canonicalise local item paths. Overrides `source_roots` in the station
# config, which is committed and so must never name a host's mount points.
ETV_STATION_SOURCE_ROOTS=

# Colon-separated list of local filesystem roots to scan for media.
# Each root's parent-directory name determines the semantic type:
#   bumpers/ → bumper, concerts/ → concert, musicvideos/ → music_video,
#   power_hours/ → power_hour, etc. Falls back to the committed fixture
#   directory (crates/etv-query-test/fixtures/) when unset.
ETV_FS_ROOTS=

# ─── Media discovery skills (radarr / sonarr) ───────────────────────────────
# Used by the /radarr and /sonarr skills (.claude/skills/) to query the
# libraries and format results as channel TOML items.

# Radarr base URL (e.g. http://100.x.x.x:7878).
RADARR_URL=<your-radarr-url>

# Radarr API key (Settings → General → API Key).
RADARR_API_KEY=<your-radarr-api-key>

# Sonarr base URL (e.g. http://100.x.x.x:8989).
SONARR_URL=<your-sonarr-url>

# Sonarr API key (Settings → General → API Key).
SONARR_API_KEY=<your-sonarr-api-key>

# Tautulli base URL (e.g. http://100.x.x.x:8181). Supplies the server-wide
# watch history a scorer plugin ranks on (#74). Unset means channels using a
# scorer plugin generate with no watch history rather than failing.
TAUTULLI_URL=<your-tautulli-url>

# Tautulli API key (Settings → Web Interface → API Key).
TAUTULLI_API_KEY=<your-tautulli-api-key>
